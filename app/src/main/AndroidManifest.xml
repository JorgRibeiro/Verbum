<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name=".VerbumApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Verbum">

        <!--
            Activity principal: tela de boas-vindas que aparece quando o usuário
            abre o app diretamente pelo launcher.
        -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Verbum"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            "Verbum: Definir" — aparece no menu de seleção de texto do Android.
            Usa tema transparente para que apenas o Bottom Sheet seja visível
            sobre o app que o usuário estava usando.
        -->
        <activity
            android:name=".ui.DefineActivity"
            android:exported="true"
            android:label="@string/action_define"
            android:noHistory="true"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@style/Theme.Verbum.Transparent">
            <intent-filter>
                <action android:name="android.intent.action.PROCESS_TEXT" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!--
            "Verbum: Traduzir" — aparece no menu de seleção de texto do Android.
            Mesmo comportamento transparente que o DefineActivity.
        -->
        <activity
            android:name=".ui.TranslateActivity"
            android:exported="true"
            android:label="@string/action_translate"
            android:noHistory="true"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@style/Theme.Verbum.Transparent">
            <intent-filter>
                <action android:name="android.intent.action.PROCESS_TEXT" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

    </application>

</manifest>
